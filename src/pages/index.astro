---
import Layout from '../layouts/Layout.astro';
import Hub from '../components/Hub';
import { config } from '../config';

const projects = config.projects.map(p => ({
  title: p.title,
  desc: p.description,
  tags: p.tags,
  live: p.live,
  source: p.source,
  android: 'android' in p ? p.android : undefined,
}));
---

<Layout>
  <Hub
    client:load
    avatar={config.avatar}
    name={config.name}
    tagline={config.tagline}
    bio={config.bio}
    github={config.github}
    linkedin={config.linkedin}
    email={config.email}
    location={config.location}
    education={config.education}
    hobbies={config.hobbies}
    aboutMd={config.about}
    skillsMd={config.skills}
    projects={projects}
    githubUsers={config.githubUsers}
    youtubeVideos={config.youtubeVideos}
    musicUrl={config.musicUrl}
    leetcode={config.leetcode}
    hackerrank={config.hackerrank}
  />
</Layout>
